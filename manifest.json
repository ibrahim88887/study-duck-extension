{
  "manifest_version": 3,
  "name": "Study Duck",
  "version": "1.0",
  "description": "Stay focused and debug smarter with your rubber duck companion. Rubber duck chat, Pomodoro timer, and task manager in one.",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Study Duck",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
